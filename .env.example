# Пример секретов для RNSquadJS.
# Скопируйте в .env (он уже в .gitignore) и подставляйте в config.json как ${VAR}.
#
# Пример использования в config.json:
#   "password": "${RCON_PASSWORD}",
#   "db": "${MONGO_URI}"

RCON_PASSWORD=changeme
MONGO_URI=mongodb://user:password@127.0.0.1:27017/
